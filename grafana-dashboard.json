{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL NaturaPiscis",
      "description": "Conexión a la base de datos PostgreSQL del backend",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Monitoreo de sensores de laguna de Tambaqui — NaturaPiscis",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🐟 Estado Actual de la Laguna",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 25, "max": 34,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 25 },
              { "color": "orange", "value": 32 },
              { "color": "red", "value": 34 }
            ]
          },
          "unit": "celsius",
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "🌡️ Temperatura",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT temperatura FROM sensor_readings ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 6, "max": 9,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 6.5 },
              { "color": "orange", "value": 8 },
              { "color": "red", "value": 8.5 }
            ]
          },
          "unit": "none",
          "decimals": 1,
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "⚗️ pH",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT ph FROM sensor_readings ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0, "max": 60,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 40 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "none",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "💧 Turbidez (NTU)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT turbidez FROM sensor_readings ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "false": { "text": "APAGADA" }, "true": { "text": "ENCENDIDA" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      },
      "title": "⚙️ Bomba de Agua",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT CASE WHEN bomba THEN 1 ELSE 0 END as bomba FROM sensor_readings ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "📈 Historial de Sensores",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 32 },
              { "color": "red", "value": 34 }
            ]
          }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "🌡️ Temperatura en el tiempo",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT timestamp AS \"time\", temperatura FROM sensor_readings WHERE $__timeFilter(timestamp) ORDER BY timestamp ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "none",
          "decimals": 2
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "⚗️ pH en el tiempo",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT timestamp AS \"time\", ph FROM sensor_readings WHERE $__timeFilter(timestamp) ORDER BY timestamp ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 40 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "💧 Turbidez en el tiempo (NTU)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT timestamp AS \"time\", turbidez FROM sensor_readings WHERE $__timeFilter(timestamp) ORDER BY timestamp ASC",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bomba" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "false": { "text": "Apagada", "color": "red" }, "true": { "text": "Encendida", "color": "green" } }, "type": "value" }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "temperatura" },
            "properties": [{ "id": "unit", "value": "celsius" }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "timestamp", "desc": true }]
      },
      "title": "📋 Últimas Lecturas",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT timestamp, temperatura, ph, turbidez, bomba FROM sensor_readings ORDER BY timestamp DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["naturapiscis", "iot", "sensores", "tambaqui"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NaturaPiscis — Monitoreo de Laguna",
  "uid": "naturapiscis-sensores",
  "version": 1
}
